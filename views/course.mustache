
{{> head}}
{{> header}}

<article>
  <h1>{{course.title}}</h1>

  <p class="muted">
    Level: {{course.level}} • Type: {{course.type}} 
    {{#course.allowDropIn}} • Drop-in available{{/course.allowDropIn}}
  </p>
  <p><strong>Location:</strong> {{course.location}} | <strong>Price:</strong> £{{course.price}}</p>
  <p>{{course.description}}</p>
  <p class="muted">Dates: {{course.startDate}} – {{course.endDate}}</p>

  <section>
    <h2>Book the full course</h2>
    <!-- If you add CSRF later: <input type="hidden" name="_csrf" value="{{csrfToken}}"> -->
    <form action="/courses/{{course.id}}/book" method="post">  
      <input type="hidden" name="userId" value="{{user._id}}">
      <button class="btn primary" type="submit">Book full course</button>
    </form>
  </section>

  <section>
    <h2>Sessions</h2>
    <table class="table">
      <thead>
        <tr> <th>Start</th>
          <th>End</th>
          <th>Availability</th>
          <th>Action</th>
        </tr>
      </thead>

      <tbody>
        {{#sessions}}
        <tr>
          <td>{{start}}</td>
          <td>{{end}}</td>
          <td>{{remaining}} / {{capacity}}</td>
          <td>
            {{#course.allowDropIn}}
            <form method="POST" action="/sessions/{{id}}/book">
              <button class="btn" type="submit" {{#isFull}}disabled{{/isFull}}>
                {{#isFull}}Full{{/isFull}}
                {{^isFull}}Book Session{{/isFull}}
              </button>

            </form>
            {{/course.allowDropIn}}
            {{^course.allowDropIn}}
              <span class="muted">Full course only</span>
            {{/course.allowDropIn}}
          </td>
        </tr>
        {{/sessions}}
      </tbody>
    </table>
  </section>
</article>

{{> footer}}
