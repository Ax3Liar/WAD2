{{> head}}
{{> header}}

<section class="filters">
  <form method="GET" action="/courses">
    <select name="level">
      <option value="" {{^filters.level}}selected{{/filters.level}}>Any Level</option>
      <option value="beginner" {{#isBeginner}}selected{{/isBeginner}}>Beginner</option>
    </select>

 <label>
      Search
      <input type="search" name="q" value="{{filters.q}}" placeholder="Title or description" />
    </label>

    <button class="btn" type="submit">Apply</button>
    <a href="/courses">Reset</a>
  </form>
</section>

<div class="cards">
  {{#courses}}
  <article class="card">
    <h2><a href="/courses/{{id}}">{{title}}</a></h2>
    <p class="muted">
      Level: {{level}} • Type: {{type}} {{#allowDropIn}}• Drop-in OK{{/allowDropIn}}
    </p>
    <p><strong>Location:</strong> {{location}} | <strong>Price:</strong> £{{price}}</p>
    <p>{{description}}</p>
    <p class="muted">Dates: {{startDate}} – {{endDate}}</p>
    <p class="muted">Next session: {{nextSession}} • Sessions: {{sessionsCount}}</p>
    <p><a href="/courses/{{id}}" class="btn">View & Book</a></p>
  </article>
  {{/courses}}

  {{^courses}}
    <p>No courses match your filters.</p>
  {{/courses}}
</div>

{{> footer}}

