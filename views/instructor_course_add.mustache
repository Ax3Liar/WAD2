{{> header}}
<main class="container">
    <h1>{{#isEdit}}Edit Course{{/isEdit}}{{^isEdit}}Add New Course{{/isEdit}}</h1>

    <form action="{{action}}" method="POST" class="admin-form">
        <div class="form-group">
            <label for="title">Course Title</label>
            <input type="text" id="title" name="title" value="{{course.title}}" required>
        </div>

        <div class="form-row">
            <div class="form-group">
                <label for="level">Difficulty Level</label>
                <select id="level" name="level">
                    <option value="beginner" {{#levelBeginner}}selected{{/levelBeginner}}>Beginner</option>
                    <option value="intermediate" {{#levelIntermediate}}selected{{/levelIntermediate}}>Intermediate</option>
                    <option value="advanced" {{#levelAdvanced}}selected{{/levelAdvanced}}>Advanced</option>
                </select>
            </div>
            <div class="form-group">
                <label for="price">Price (£)</label>
                <input type="number" id="price" name="price" step="0.01" value="{{course.price}}" required>
            </div>
        </div>

        <div class="form-group">
            <label for="location">Location</label>
            <input type="text" id="location" name="location" value="{{course.location}}" required placeholder="e.g. Studio A or Zoom">
        </div>

        <div class="form-group">
            <label for="description">Description</label>
            <textarea id="description" name="description" rows="5">{{course.description}}</textarea>
        </div>

        <div class="form-group">
            <label>
                <input type="checkbox" name="allowDropIn" {{#course.allowDropIn}}checked{{/course.allowDropIn}}>
                Allow individual session bookings (Drop-in)
            </label>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn btn-primary">Save Course</button>
            <a href="/instructor/dashboard" class="btn btn-secondary">Cancel</a>
        </div>
    </form>
</main>
{{> footer}}