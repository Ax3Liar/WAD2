<header class="site-header">
  <div class="wrap">
    <a href="/" class="logo">🧘 Yoga Studio</a>
    
    <nav>
      <a href="/">Home</a>
      <a href="/courses">Courses</a>
      
      {{^user}}
        <a href="/register">Register</a>
      {{/user}}

      {{#user}}
        {{#isOrganiser}}
          <a href="/courses/add">Admin: Add Course</a>
        {{/isOrganiser}}
      {{/user}}
    </nav>

    {{#user}}
    <div class="user-info">
      Signed in as <strong>{{ name }}</strong> 
      <small>({{ role }})</small>
    </div>
    {{/user}}
  </div>
</header>